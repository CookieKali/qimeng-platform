.page-wrap {
  background: var(--qm-bg, #0a0b0f);
  min-height: 100vh;
  box-sizing: border-box;
}

.post-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px 12px;
  background: rgba(15, 17, 23, 0.92);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--qm-border);
  position: sticky;
  top: 0;
  z-index: 20;
}

.post-nav-side {
  min-width: 56px;
  font-size: 14px;
  font-weight: 600;
}

.post-nav-cancel {
  color: #9499B0;
}

.post-nav-submit {
  color: var(--qm-accent-light, #60a5fa);
  text-align: right;
}

.post-nav-title {
  font-size: 17px;
  font-weight: 700;
  color: #F1F3F9;
}

.post-body {
  padding: 16px 16px 120px;
}

.post-hint {
  font-size: 12px;
  color: #9499B0;
  line-height: 1.7;
  padding: 12px 14px;
  background: rgba(59, 130, 246, 0.08);
  border: 1px solid rgba(59, 130, 246, 0.2);
  border-radius: 12px;
  margin-bottom: 16px;
}

.post-ft {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
  background: rgba(15, 17, 23, 0.96);
  border-top: 1px solid var(--qm-border);
  backdrop-filter: blur(20px);
}

.post-ft .btn {
  width: 100%;
}

.credits-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.credits-row .fi {
  flex: 1;
}

.credits-unit {
  font-size: 13px;
  color: #9499B0;
  font-weight: 600;
  flex-shrink: 0;
}

.cover-fg {
  margin-bottom: 16px;
}

.cover-box {
  width: 100%;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.04);
  border: 1.5px dashed rgba(91, 141, 239, 0.35);
  border-radius: 12px;
  box-sizing: border-box;
}

.cover-placeholder {
  font-size: 13px;
  color: #8aa8c8;
  font-weight: 500;
}

.cover-preview-wrap {
  position: relative;
  width: 100%;
  height: 160rpx;
  border-radius: 12px;
  overflow: hidden;
}

.cover-preview {
  width: 100%;
  height: 160rpx;
  display: block;
}

.cover-upload-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 13px;
  font-weight: 600;
}

.cover-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  z-index: 2;
}

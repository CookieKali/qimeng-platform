.page-wrap {
  background: var(--qm-bg, #0a0b0f);
  min-height: 100vh;
  box-sizing: border-box;
}

.post-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px 12px;
  background: rgba(15, 17, 23, 0.92);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--qm-border, rgba(255, 255, 255, 0.06));
  position: sticky;
  top: 0;
  z-index: 20;
}

.post-nav-side {
  min-width: 56px;
  font-size: 14px;
  font-weight: 600;
}

.post-nav-cancel {
  color: #9499b0;
}

.post-nav-title {
  font-size: 17px;
  font-weight: 700;
  color: #f1f3f9;
}

.post-body {
  padding: 16px 16px 120px;
  box-sizing: border-box;
}

.post-hint {
  font-size: 12px;
  color: #9499b0;
  line-height: 1.7;
  padding: 12px 14px;
  background: rgba(59, 130, 246, 0.08);
  border: 1px solid rgba(59, 130, 246, 0.2);
  border-radius: 12px;
  margin-bottom: 16px;
}

.post-ft {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
  background: rgba(15, 17, 23, 0.96);
  border-top: 1px solid var(--qm-border, rgba(255, 255, 255, 0.06));
  backdrop-filter: blur(20px);
  box-sizing: border-box;
}

.post-ft .btn {
  flex: none !important;
  width: 100%;
  box-sizing: border-box;
}

.post-ft .btn-disabled {
  opacity: 0.55;
  pointer-events: none;
}

.datetime-row {
  display: flex;
  gap: 10px;
}

.datetime-row picker {
  flex: 1;
  min-width: 0;
}

.datetime-row .fsl {
  width: 100%;
  box-sizing: border-box;
}

.datetime-row .time-pick {
  min-width: 96px;
  text-align: center;
}

.page-wrap .fi,
.page-wrap .fta,
.page-wrap .fsl {
  background: var(--qm-surface-2, #1e2434);
  border: 1px solid var(--qm-border, #2a2d3a);
  color: var(--qm-text, #f1f3f9);
}

.page-wrap .fi.error {
  border-color: #f87171;
}

.page-wrap .fl {
  color: var(--qm-text-secondary, #9499b0);
}

.required {
  color: #f87171;
}

.field-error {
  display: block;
  font-size: 11px;
  color: #f87171;
  margin-top: 4px;
}

.cover-fg {
  margin-bottom: 16px;
}

.cover-box {
  width: 100%;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.04);
  border: 1.5px dashed rgba(91, 141, 239, 0.35);
  border-radius: 12px;
  box-sizing: border-box;
  gap: 8px;
}

.cover-placeholder {
  font-size: 13px;
  color: #8aa8c8;
  font-weight: 500;
}

.cover-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #8aa8c8;
}

.cover-loading-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(91, 141, 239, 0.3);
  border-top-color: #5b8def;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.cover-preview-wrap {
  position: relative;
  width: 100%;
  height: 160rpx;
  border-radius: 12px;
  overflow: hidden;
}

.cover-preview {
  width: 100%;
  height: 160rpx;
  display: block;
}

.cover-upload-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 13px;
  font-weight: 600;
}

.cover-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  z-index: 2;
}

.fg-readonly {
  opacity: 0.72;
}

.fg-readonly .fsl {
  color: #9499b0;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.success-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 20px;
  box-sizing: border-box;
}

.success-modal {
  background: var(--qm-surface, #18191f);
  border: 1px solid var(--qm-border, #2a2d3a);
  border-radius: 16px;
  padding: 32px 24px 24px;
  width: 100%;
  max-width: 320px;
  text-align: center;
  box-sizing: border-box;
}

.success-icon {
  width: 64px;
  height: 64px;
  line-height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, #34d399, #10b981);
  color: #fff;
  font-size: 32px;
  margin: 0 auto 20px;
  font-weight: 700;
}

.success-title {
  font-size: 20px;
  font-weight: 700;
  color: #f1f3f9;
  margin-bottom: 8px;
}

.success-desc {
  font-size: 13px;
  color: #9499b0;
  line-height: 1.6;
  margin-bottom: 24px;
}

.success-actions {
  display: flex;
  gap: 12px;
}

.success-actions .btn {
  flex: 1 !important;
  min-width: 0;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #f1f3f9;
  border: 1px solid var(--qm-border, #2a2d3a);
}

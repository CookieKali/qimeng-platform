.page-wrap {
  background: transparent;
}

.page-wrap .seg {
  margin: 10px 16px 0;
}

.page-wrap .at {
  font-size: 15px;
  color: #F1F3F9;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 8px;
}

.page-wrap .ad {
  font-size: 12px;
  color: #9499B0;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  font-weight: 500;
  margin-bottom: 8px;
}

.page-wrap .ad-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
  font-size: 12px;
  color: #9499B0;
}

.page-wrap .ad-time,
.page-wrap .ad-location {
  display: flex;
  align-items: center;
  gap: 4px;
}

.page-wrap .am {
  font-size: 12px;
  color: #9499B0;
  line-height: 1.9;
}

.page-wrap .am-capacity,
.page-wrap .am-host {
  display: flex;
  align-items: center;
  gap: 8px;
}

.page-wrap .am-label {
  font-size: 11px;
  color: #6B7280;
}

.page-wrap .am-value {
  color: #a8c8e8;
  font-weight: 700;
}

.page-wrap .am-desc {
  margin-top: 4px;
  color: #8aa8c8;
}

/* Activity type tags */
.page-wrap .pl.pg,
.page-wrap .pl.pf {
  background: rgba(52, 211, 153, 0.1);
  color: #34D399;
  border: 1px solid rgba(52, 211, 153, 0.25);
}

.page-wrap .pl.pb,
.page-wrap .pl.pb2 {
  background: rgba(59, 130, 246, 0.1);
  color: var(--qm-accent-light);
  border: 1px solid rgba(59, 130, 246, 0.25);
}

.page-wrap .pl.ph {
  background: rgba(251, 191, 36, 0.1);
  color: #FBBF24;
  border: 1px solid rgba(251, 191, 36, 0.25);
}

.page-wrap .signup-prog {
  margin-top: 10px;
}

.page-wrap .signup-prog-track {
  background: var(--qm-border);
  border-radius: 4px;
  height: 4px;
  overflow: hidden;
}

.page-wrap .signup-prog-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--qm-accent-light), #34D399);
  border-radius: 4px;
}

/* Activity item */
.activity-list {
  padding: 0 16px;
}

.activity-item {
  margin-bottom: 12px;
}

.ac-cover {
  width: 100%;
  height: 160px;
  border-radius: 12px 12px 0 0;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.05);
}

.ac-cover-img {
  width: 100%;
  height: 100%;
}

.btn-checkin {
  display: block;
  width: 100%;
  margin-bottom: 14px;
  padding: 11px 0;
  text-align: center;
  font-size: 14px;
  font-weight: 700;
  color: var(--qm-bg);
  background: #34D399;
  border-radius: 12px;
  border: none;
  box-sizing: border-box;
}

/* Skeleton loading */
.skeleton-card {
  padding: 20px 16px;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12px;
  margin: 12px 16px;
}

.skeleton-line {
  height: 14px;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.05) 25%, rgba(255, 255, 255, 0.1) 50%, rgba(255, 255, 255, 0.05) 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 4px;
  margin-bottom: 8px;
}

.skeleton-line-wide {
  width: 100%;
  margin-bottom: 12px;
}

.skeleton-line-narrow {
  width: 60%;
}

.skeleton-line-short {
  width: 40%;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* Load more */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px 16px;
  gap: 8px;
}

.load-more-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(91, 141, 239, 0.3);
  border-top-color: #5B8DEF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.load-more-text {
  font-size: 12px;
  color: #9499B0;
}

.attendees-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.attendees-title {
  font-size: 11px;
  color: #4A4D65;
  font-weight: 600;
  letter-spacing: 0.06em;
}

.attendees-protected {
  font-size: 10px;
  color: #9499B0;
  font-weight: 500;
}

.attendees-list {
  margin: 0;
}

.attendee-row {
  align-items: center;
}

.attendee-av {
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.attendee-av-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.attendee-main {
  flex: 1;
  min-width: 0;
}

.attendee-me {
  font-size: 10px;
  color: var(--qm-accent-light);
  font-weight: 600;
  margin-left: 4px;
}

.attendee-action .btn-sm {
  padding: 5px 10px;
  font-size: 11px;
  white-space: nowrap;
}

.attendees-empty {
  font-size: 12px;
  color: #4A4D65;
  text-align: center;
  padding: 16px;
  font-weight: 500;
}

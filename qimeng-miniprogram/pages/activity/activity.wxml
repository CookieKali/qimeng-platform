<view class="page-wrap" style="padding-top:{{headerHeight}}px;padding-bottom:{{pageBottom}}px">
  <view class="nav">
    <text class="nav-t">活动</text>
  </view>

  <view class="seg">
    <view class="sb2 {{actSub === 0 ? 'on' : ''}}" bindtap="switchSub" data-n="0">全部</view>
    <view class="sb2 {{actSub === 1 ? 'on' : ''}}" bindtap="switchSub" data-n="1">即将开始</view>
    <view class="sb2 {{actSub === 2 ? 'on' : ''}}" bindtap="switchSub" data-n="2">进行中</view>
    <view class="sb2 {{actSub === 3 ? 'on' : ''}}" bindtap="switchSub" data-n="3">已结束</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="skeleton-card" wx:for="{{[1,2]}}" wx:key="*this">
      <view class="skeleton-line skeleton-line-wide"></view>
      <view class="skeleton-line skeleton-line-narrow"></view>
    </view>
  </block>
  <block wx:else>
  <view class="sec">{{subLabel}} ({{displayActivities.length}})</view>
  <view class="empty-state" wx:if="{{displayActivities.length === 0}}">
    <view class="empty-icon"><text class="sym-icon">📅</text></view>
    <view class="empty-text">近期暂无活动，敬请期待</view>
  </view>

  <view wx:for="{{displayActivities}}" wx:key="id">
    <view class="ac" hover-class="tc-press" hover-stay-time="80">
      <view class="ah">
        <view class="ad">
          {{item.date}}　<text class="pl {{item.typeClass}}">{{item.type}}</text>
          <text wx:if="{{item.isJoined}}" class="pl pf" style="margin-left:4px">已报名</text>
        </view>
        <view class="at">{{item.title}}</view>
      </view>
      <view class="ab">
        <view class="am">
          <view>地点：<text style="color:#a8c8e8;font-weight:700">{{item.space}}</text></view>
          <view>名额：<text style="color:#a8c8e8;font-weight:700">{{item.signups}}/{{item.seats}} 人</text></view>
          <view style="color:#8aa8c8;margin-top:2px;font-weight:500">{{item.desc}}</view>
        </view>
        <view class="sf2">
          <view class="btn bs" bindtap="openDetail" data-id="{{item.id}}">查看</view>
          <view class="btn bp" wx:if="{{item.status === 'upcoming' && !item.isJoined}}"
                bindtap="openSignup" data-id="{{item.id}}">报名</view>
          <view class="btn bs" wx:elif="{{item.status === 'upcoming' && item.isJoined}}">已报名</view>
          <view class="btn bs" wx:else>{{item.status === 'ongoing' ? '进行中' : '已结束'}}</view>
          <view class="btn bp share-wx-btn" open-type="share" bindtap="prepareShareActivity" data-id="{{item.id}}">分享</view>
        </view>
      </view>
    </view>
  </view>
  </block>
</view>

<!-- 报名弹窗 -->
<view class="ov" wx:if="{{modal === 'signup' && selectedActivity}}" bindtap="closeModal">
  <view class="mb" catchtap="stopProp">
    <view class="mh">
      <text class="mht">活动报名</text>
      <view class="mx" bindtap="closeModal">×</view>
    </view>
    <view class="mbody">
      <view class="hb">
        <view style="font-size:10px;color:#5cb8ff;font-weight:800">{{selectedActivity.date}}</view>
        <view style="font-size:14px;font-weight:800;color:#e0eefc;margin-top:3px">{{selectedActivity.title}}</view>
        <view style="font-size:11px;color:#7090b0;margin-top:3px;font-weight:500">{{selectedActivity.space}}</view>
      </view>
      <view class="fg">
        <text class="fl">备注需求</text>
        <textarea class="fta" placeholder="如：需要投影、白板..."></textarea>
      </view>
      <view class="fg">
        <text class="fl">同行者</text>
        <input class="fi" placeholder="姓名，逗号分隔（选填）" />
      </view>
      <view class="btn bp" bindtap="confirmSignup" data-id="{{selectedActivity.id}}">确认报名</view>
    </view>
  </view>
</view>

<!-- 活动详情弹窗 -->
<view class="ov" wx:if="{{modal === 'detail' && selectedActivity}}" bindtap="closeModal">
  <view class="mb" catchtap="stopProp">
    <view class="mh">
      <text class="mht">活动详情</text>
      <view class="mx" bindtap="closeModal">×</view>
    </view>
    <view class="mbody">
      <view class="hb">
        <view style="font-size:14px;font-weight:800;color:#e0eefc;margin-bottom:6px">{{selectedActivity.title}}</view>
        <view style="display:flex;gap:5px;margin-bottom:8px">
          <text class="pl {{selectedActivity.typeClass}}">{{selectedActivity.type}}</text>
          <text class="pl {{selectedActivity.statusCls}}">{{selectedActivity.statusLabel}}</text>
        </view>
        <view style="font-size:11px;color:#7090b0;line-height:2;font-weight:500">
          <view>时间：<text style="color:#a8c8e8;font-weight:700">{{selectedActivity.date}}</text></view>
          <view>地点：<text style="color:#a8c8e8;font-weight:700">{{selectedActivity.space}}</text></view>
          <view>报名：<text style="color:#a8c8e8;font-weight:700">{{selectedActivity.signups}}/{{selectedActivity.seats}} 人</text></view>
        </view>
      </view>
      <view style="font-size:11px;color:#3a5878;font-weight:800;margin-bottom:6px">活动简介</view>
      <view style="font-size:12px;color:#8aa8c8;line-height:1.85;margin-bottom:13px;font-weight:500">{{selectedActivity.desc}}</view>

      <view class="btn btn-checkin" wx:if="{{selectedActivity.isJoined && !myChecked}}"
            bindtap="checkin" data-id="{{selectedActivity.id}}">现场签到</view>

      <block wx:if="{{myChecked}}">
        <view class="attendees-hd">
          <text class="attendees-title">到场人员 ({{attendeesTotal}})</text>
          <text class="attendees-protected" wx:if="{{attendeesExpired}}">信息已保护</text>
        </view>
        <view class="cw attendees-list" wx:if="{{attendees.length > 0}}">
          <view class="mr attendee-row" wx:for="{{attendees}}" wx:key="id">
            <view class="av attendee-av" style="background:{{item.bg}};color:{{item.c}};width:32px;height:32px;font-size:11px">
              <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="attendee-av-img" mode="aspectFill" />
              <text wx:else>{{item.nameAbbr}}</text>
            </view>
            <view class="attendee-main">
              <view class="mn">{{item.name}}<text wx:if="{{item.isMe}}" class="attendee-me">（我）</text></view>
              <view class="ms" wx:if="{{item.job || item.co}}">{{item.job}}<text wx:if="{{item.job && item.co}}"> · </text>{{item.co}}</view>
            </view>
            <view class="attendee-action" wx:if="{{!item.isMe && !item.is_friend && !attendeesExpired}}">
              <view class="btn bw btn-sm" catchtap="addFriendFromAttendee" data-id="{{item.id}}">加好友</view>
            </view>
            <text class="pl pf" wx:elif="{{!item.isMe && item.is_friend}}">好友</text>
          </view>
        </view>
        <view class="attendees-empty" wx:else>暂无其他到场人员</view>
      </block>
    </view>
  </view>
</view>


<custom-tab-bar />

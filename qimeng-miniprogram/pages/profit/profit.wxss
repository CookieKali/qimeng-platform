.page-wrap { background: transparent; }

.state-box {
  margin: 24px 16px;
  padding: 20px;
  text-align: center;
  border-radius: 12px;
  background: #0c1e38;
  border: 1px solid #1a4a8a;
}

.state-err { color: #ff9898; }

.btn-retry { margin-top: 12px; display: inline-block; }

.sk-list { padding: 16px; }
.sk-row {
  height: 72px;
  margin-bottom: 12px;
  border-radius: 12px;
  background: linear-gradient(90deg, #0c1e38 25%, #142a4a 50%, #0c1e38 75%);
  background-size: 200% 100%;
  animation: sk-shine 1.2s ease-in-out infinite;
}
@keyframes sk-shine {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.profit-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.profit-record-row {
  align-items: flex-start;
}

.profit-record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
  flex-shrink: 0;
}

.profit-confirm-btn {
  font-size: 10px;
  font-weight: 800;
  color: #5cb8ff;
  padding: 4px 10px;
  border: 1px solid #1a4a8a;
  border-radius: 8px;
  background: #0c1e38;
}

.dash-card {
  margin: 10px 12px;
  padding: 14px;
  background: #091626;
  border: 1.5px solid #1a3860;
  border-radius: 15px;
}

.dash-period {
  font-size: 11px;
  color: #7090b0;
  font-weight: 600;
  margin-bottom: 8px;
}

.dash-label {
  font-size: 11px;
  color: #5080a0;
  font-weight: 700;
}

.dash-val {
  font-size: 28px;
  font-weight: 900;
  color: var(--qm-accent-light);
  margin-top: 4px;
}

.dash-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 14px;
}

.dash-cell {
  flex: 1;
  min-width: 40%;
  background: #070d1a;
  border: 1px solid #1c2840;
  border-radius: 9px;
  padding: 9px;
  text-align: center;
}

.dash-cell-label {
  font-size: 10px;
  color: #3a5878;
  font-weight: 700;
}

.dash-cell-val {
  font-size: 14px;
  font-weight: 800;
  color: #e0eefc;
  margin-top: 4px;
}

.dash-cell-val.warn {
  color: #e8b040;
}

.quota-row {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid #1a3860;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 6px;
}

.quota-label {
  font-size: 11px;
  color: #7090b0;
  font-weight: 600;
}

.quota-val {
  font-size: 16px;
  font-weight: 900;
  color: #28e880;
}

.quota-sub {
  width: 100%;
  font-size: 10px;
  color: #3a5878;
  font-weight: 600;
}

.list-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 11px 13px;
  border-bottom: 1px solid #121e30;
}

.list-row:last-child {
  border-bottom: none;
}

.list-title {
  font-size: 13px;
  color: #c8d8f0;
  font-weight: 700;
}

.list-sub {
  font-size: 10px;
  color: #3a5878;
  margin-top: 3px;
  font-weight: 600;
}

.list-amt {
  font-size: 14px;
  font-weight: 900;
  color: #28e880;
  flex-shrink: 0;
  margin-left: 8px;
}

.empty-hint {
  padding: 20px 13px;
  text-align: center;
  font-size: 12px;
  color: #3a5878;
  font-weight: 600;
}

.channel-card {
  padding: 12px 13px;
}

.channel-link-row {
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #121e30;
}

.channel-link-label {
  font-size: 11px;
  color: #7090b0;
  font-weight: 700;
  margin-bottom: 6px;
}

.channel-link-text {
  font-size: 12px;
  color: var(--qm-accent-light);
  font-weight: 600;
  word-break: break-all;
  line-height: 1.5;
  margin-bottom: 8px;
}

.channel-copy-btn {
  display: inline-block;
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 700;
  color: #e0eefc;
  background: #0c1e38;
  border: 1px solid #1a4a8a;
  border-radius: 8px;
}

.channel-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.channel-cell {
  flex: 1;
  min-width: 40%;
  background: #070d1a;
  border: 1px solid #1c2840;
  border-radius: 9px;
  padding: 9px;
  text-align: center;
}

.channel-cell-label {
  font-size: 10px;
  color: #3a5878;
  font-weight: 700;
}

.channel-cell-val {
  font-size: 14px;
  font-weight: 800;
  color: #e0eefc;
  margin-top: 4px;
}

.channel-cell-val.accent {
  color: #28e880;
}

<view class="page-wrap" style="padding-top:{{headerHeight}}px;padding-bottom:{{pageBottom}}px">
  <view class="nav inbox-nav">
    <view class="nav-back" bindtap="goBack">‹</view>
    <text class="nav-t">消息</text>
    <view class="inbox-nav-actions">
      <text class="nav-sub" wx:if="{{mainTab === 0 && unreadCount > 0}}">{{unreadCount}} 未读</text>
      <text class="nav-sub" wx:if="{{mainTab === 1 && dmUnreadTotal > 0}}">{{dmUnreadTotal}} 未读</text>
      <text class="inbox-mark-all" wx:if="{{mainTab === 0 && unreadCount > 0}}" bindtap="markAllRead">全部已读</text>
    </view>
  </view>

  <view class="seg inbox-seg">
    <view class="sb2 {{mainTab === 0 ? 'on' : ''}}" bindtap="switchMainTab" data-n="0">通知</view>
    <view class="sb2 {{mainTab === 1 ? 'on' : ''}}" bindtap="switchMainTab" data-n="1">
      私信
      <view class="inbox-tab-dot" wx:if="{{dmUnreadTotal > 0}}"></view>
    </view>
  </view>

  <!-- 通知 -->
  <block wx:if="{{mainTab === 0}}">
    <view class="sk-list" wx:if="{{loading && !refreshing}}">
      <view class="sk-row" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
    </view>

    <view class="state-box state-err" wx:elif="{{loadError}}">
      <text>{{loadError}}</text>
      <view class="btn bp btn-retry" bindtap="_loadNotify">点击重试</view>
    </view>

    <view class="empty-inline" wx:elif="{{messages.length === 0}}">
      <view class="empty-icon"><text class="sym-icon">✉️</text></view>
      <view class="empty-title">暂无消息</view>
      <view class="empty-desc">名片转发、好友申请、任务与活动通知会显示在这里</view>
    </view>

    <view class="inbox-list" wx:else>
      <view
        class="inbox-item {{item.is_read ? '' : 'unread'}}"
        wx:for="{{messages}}"
        wx:key="id"
        bindtap="openMessage"
        data-id="{{item.id}}"
        data-type="{{item.type}}"
        data-related="{{item.related_id}}"
        data-idx="{{index}}"
        hover-class="inbox-item-press"
        hover-stay-time="80"
      >
        <view class="inbox-icon-wrap" style="background:{{item.typeColor}}22">
          <text class="sym-icon inbox-sym">{{item.iconSym}}</text>
          <view class="inbox-dot" wx:if="{{!item.is_read}}"></view>
        </view>
        <view class="inbox-body">
          <view class="inbox-head">
            <text class="inbox-type-tag" style="color:{{item.typeColor}};border-color:{{item.typeColor}}44;background:{{item.typeColor}}18">{{item.typeLabel}}</text>
            <text class="inbox-time">{{item.created_at}}</text>
          </view>
          <text class="inbox-title">{{item.title}}</text>
          <view class="inbox-summary" wx:if="{{item.summary}}">{{item.summary}}</view>
          <view class="inbox-meta-row">
            <text class="inbox-from" wx:if="{{item.from_name}}">来自 {{item.from_name}}</text>
            <text class="inbox-action" wx:if="{{item.actionHint}}">{{item.actionHint}} ›</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 私信 -->
  <block wx:else>
    <view class="sk-list" wx:if="{{dmLoading && !refreshing}}">
      <view class="sk-row" wx:for="{{[1,2,3,4]}}" wx:key="*this"></view>
    </view>

    <view class="state-box state-err" wx:elif="{{dmLoadError}}">
      <text>{{dmLoadError}}</text>
      <view class="btn bp btn-retry" bindtap="_loadConversations">点击重试</view>
    </view>

    <view class="empty-inline" wx:elif="{{conversations.length === 0}}">
      <view class="empty-icon"><text class="sym-icon">✉️</text></view>
      <view class="empty-title">暂无私信</view>
      <view class="empty-desc">在好友名片中点击「发消息」开始聊天</view>
    </view>

    <view class="inbox-list dm-list" wx:else>
      <view
        class="dm-item"
        wx:for="{{conversations}}"
        wx:key="user_id"
        bindtap="openConversation"
        data-user-id="{{item.user_id}}"
        data-name="{{item.name}}"
        hover-class="inbox-item-press"
        hover-stay-time="80"
      >
        <view class="dm-av-wrap">
          <view class="dm-av" style="background:{{item.avatarBg}};color:{{item.avatarC}}">
            <image wx:if="{{item.avatarUrl}}" class="dm-av-img" src="{{item.avatarUrl}}" mode="aspectFill" />
            <text wx:else>{{item.nameAbbr}}</text>
          </view>
          <view class="dm-dot" wx:if="{{item.unread_count > 0}}"></view>
        </view>
        <view class="inbox-body">
          <view class="inbox-title-row">
            <text class="inbox-title">{{item.name}}</text>
            <text class="inbox-time">{{item.last_time}}</text>
          </view>
          <view class="inbox-summary dm-preview">{{item.last_message}}</view>
        </view>
        <view class="dm-unread-badge" wx:if="{{item.unread_count > 0}}">{{item.unread_count > 99 ? '99+' : item.unread_count}}</view>
      </view>
    </view>
  </block>
</view>

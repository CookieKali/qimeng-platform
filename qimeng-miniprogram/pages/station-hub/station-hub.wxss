/* Banner 封面 */
.hub-banner {
  position: relative;
  width: 100%;
  height: 180px;
  overflow: hidden;
}

.hub-banner-img {
  width: 100%;
  height: 100%;
  display: block;
}

.hub-banner-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(145deg, #0d2248 0%, #0f2a56 50%, #071830 100%);
}

.hub-banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px 14px;
  background: linear-gradient(0deg, rgba(4,10,24,0.92) 0%, rgba(4,10,24,0.4) 60%, transparent 100%);
}

.hub-banner-name {
  font-size: 20px;
  font-weight: 900;
  color: #edf4ff;
  line-height: 1.3;
}

.hub-banner-meta {
  font-size: 12px;
  color: rgba(160, 200, 255, 0.65);
  margin-top: 4px;
  font-weight: 600;
}

/* 简介卡 */
.hub-info-card {
  margin: 10px 12px 0;
  padding: 14px 16px;
  background: #091626;
  border: 1px solid #1a3860;
  border-radius: 14px;
}

.hub-desc {
  font-size: 13px;
  color: #a8c8e8;
  line-height: 1.7;
  margin-bottom: 8px;
}

.hub-operator-row {
  display: flex;
  align-items: center;
  gap: 7px;
}

.hub-operator-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #5cb8ff;
  flex-shrink: 0;
}

.hub-operator-text {
  font-size: 12px;
  color: #5cb8ff;
  font-weight: 700;
}

/* 统计数据 */
.hub-stats {
  display: flex;
  gap: 8px;
  margin: 10px 12px 0;
}

.hub-stat {
  flex: 1;
  padding: 12px 8px;
  background: #0c1e38;
  border: 1px solid #1a3860;
  border-radius: 12px;
  text-align: center;
}

.hub-stat-val {
  font-size: 18px;
  font-weight: 900;
  color: #5cb8ff;
}

.hub-stat-k {
  font-size: 10px;
  color: #7090b0;
  margin-top: 4px;
  font-weight: 600;
}

/* 场地卡片 */
.hub-space-card {
  margin: 0 12px 10px;
  background: #091626;
  border: 1px solid #1a3860;
  border-radius: 14px;
  overflow: hidden;
}

.hub-space-cover {
  position: relative;
  width: 100%;
  height: 110px;
}

.hub-space-cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.hub-space-cover-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #0d2040 0%, #0a1830 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hub-space-cover-icon {
  font-size: 32px;
  opacity: 0.4;
}

.hub-space-type-tag {
  position: absolute;
  bottom: 8px;
  left: 10px;
  font-size: 10px;
  font-weight: 700;
  color: #e0f0ff;
  background: rgba(10, 20, 40, 0.72);
  border: 1px solid rgba(80, 140, 220, 0.35);
  border-radius: 20px;
  padding: 2px 9px;
}

.hub-space-info {
  padding: 12px 14px 14px;
}

.hub-space-name {
  font-size: 15px;
  font-weight: 800;
  color: #e0eefc;
  margin-bottom: 6px;
}

.hub-space-sub-row {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-bottom: 10px;
}

.hub-space-chip {
  font-size: 10px;
  font-weight: 600;
  color: #6a8aaa;
  background: rgba(20, 40, 80, 0.5);
  border: 1px solid rgba(28, 56, 96, 0.8);
  border-radius: 20px;
  padding: 2px 8px;
}

.hub-space-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid rgba(26, 56, 96, 0.5);
  padding-top: 8px;
}

.hub-space-price {
  font-size: 13px;
  font-weight: 800;
  color: #fbbf24;
}

.hub-space-free {
  color: #34d399;
}

.hub-space-book-btn {
  font-size: 12px;
  font-weight: 700;
  color: #5cb8ff;
}

/* 股东卡片 */
.hub-sh-card {
  margin: 0 12px 8px;
  padding: 12px 14px;
  background: #0c1e38;
  border: 1px solid #1a3860;
  border-radius: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.hub-sh-avatar {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1a3a6a, #0d2248);
  border: 1.5px solid #1e4a8a;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 14px;
  font-weight: 800;
  color: #5cb8ff;
}

.hub-sh-info {
  flex: 1;
  min-width: 0;
}

.hub-sh-name {
  font-size: 14px;
  font-weight: 800;
  color: #e0eefc;
}

.hub-sh-sub {
  font-size: 11px;
  color: #7090b0;
  margin-top: 3px;
  font-weight: 600;
}

/* 结算行 */
.hub-settle-row {
  margin: 0 12px 8px;
  padding: 12px 14px;
  background: #0c1e38;
  border: 1px solid #1a3860;
  border-radius: 12px;
}

.hub-settle-period {
  font-size: 14px;
  font-weight: 800;
  color: #e0eefc;
}

.hub-settle-sub {
  font-size: 11px;
  color: #7090b0;
  margin-top: 4px;
  font-weight: 600;
}

.hub-empty,
.hub-loading {
  text-align: center;
  padding: 24px;
  font-size: 13px;
  color: #7090b0;
  font-weight: 600;
}

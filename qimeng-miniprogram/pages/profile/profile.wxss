.page-wrap {
  background: transparent;
}

.profile-completeness {
  margin: 8px 12px 4px;
  padding: 12px 14px;
  background: var(--qm-surface);
  border: 1px solid var(--qm-border);
  border-radius: 12px;
}

.pc-label {
  font-size: 12px;
  font-weight: 700;
  color: var(--qm-text-secondary);
  margin-bottom: 8px;
}

.pc-bar {
  height: 6px;
  border-radius: 999px;
  background: var(--qm-surface-3);
  overflow: hidden;
}

.pc-fill {
  height: 100%;
  border-radius: 999px;
  transition: width 0.25s ease;
}

.pc-fill-red {
  background: linear-gradient(90deg, #ef4444, #f87171);
}

.pc-fill-yellow {
  background: linear-gradient(90deg, #d97706, #fbbf24);
}

.pc-fill-green {
  background: linear-gradient(90deg, #059669, #34d399);
}

.pc-tip {
  margin-top: 8px;
  font-size: 12px;
  font-weight: 600;
  color: var(--qm-accent-light);
}

/* —— 档案页：个人主页 —— */
.profile-hero {
  margin: 8px 16px 12px;
  border-radius: var(--qm-radius-lg, 20px);
  overflow: hidden;
  background: var(--qm-surface);
  border: 1px solid var(--qm-border);
  position: relative;
  box-shadow: var(--qm-shadow-card);
}

.profile-hero-bg {
  height: 72px;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.35) 0%, rgba(26, 29, 39, 0.2) 60%, transparent 100%);
}

.profile-hero-body {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 0 16px;
  margin-top: -36px;
}

.profile-hero-av {
  width: 72px;
  height: 72px;
  flex-shrink: 0;
  position: relative;
}

.profile-hero-av-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-hero-av-text {
  font-size: 22px;
  font-weight: 800;
  line-height: 72px;
  text-align: center;
  display: block;
}

.profile-hero-av-edit {
  left: 50%;
  right: auto;
  bottom: -4px;
  width: auto;
  height: auto;
  min-width: 44px;
  transform: translateX(-50%);
  border-radius: 8px;
  font-size: 9px;
  color: var(--qm-accent-light);
  padding: 2px 6px;
  white-space: nowrap;
  line-height: 14px;
  background: var(--qm-surface);
  border-color: var(--qm-border);
}

.profile-hero-info {
  flex: 1;
  min-width: 0;
  padding-top: 6px;
}

.profile-hero-name {
  font-size: 20px;
  font-weight: 700;
  color: var(--qm-text);
  line-height: 1.3;
}

.profile-hero-line {
  font-size: 13px;
  color: var(--qm-text-secondary);
  margin-top: 6px;
  line-height: 1.45;
}

.profile-hero-meta {
  font-size: 12px;
  color: var(--qm-text-tertiary);
}

.profile-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 10px;
}

.profile-hero-actions {
  display: flex;
  gap: 10px;
  padding: 14px 16px 16px;
}

.profile-btn-primary {
  flex: 1;
  text-align: center;
  padding: 11px 0;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--qm-accent-light), #3b6fd4);
  box-shadow: 0 4px 14px rgba(59, 130, 246, 0.28);
}

.profile-btn-ghost {
  flex: 1;
  text-align: center;
  padding: 11px 0;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
  color: var(--qm-accent-light);
  background: rgba(59, 130, 246, 0.1);
  border: 1px solid rgba(59, 130, 246, 0.35);
}

.profile-card-block {
  margin: 0 12px 12px;
  background: var(--qm-surface);
  border: 1px solid var(--qm-border);
  border-radius: 16px;
  overflow: hidden;
}

.profile-card-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px 10px;
}

.profile-card-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--qm-text);
}

.profile-card-link {
  font-size: 13px;
  color: var(--qm-accent-light);
  font-weight: 600;
}

.profile-card-body {
  padding: 0 16px 16px;
}

.profile-kv {
  margin-bottom: 12px;
}

.profile-kv:last-of-type {
  margin-bottom: 8px;
}

.profile-k {
  display: block;
  font-size: 12px;
  color: var(--qm-text-tertiary);
  font-weight: 600;
  margin-bottom: 4px;
}

.profile-v {
  display: block;
  font-size: 14px;
  color: #c8cdd8;
  line-height: 1.55;
}

.profile-contact-strip {
  font-size: 12px;
  color: var(--qm-text-secondary);
  padding-top: 10px;
  border-top: 1px solid var(--qm-border);
  line-height: 1.6;
}

.profile-card-empty {
  padding: 20px 16px 24px;
  text-align: center;
}

.profile-card-empty-icon {
  font-size: 40px;
  display: block;
  margin-bottom: 8px;
  opacity: 0.7;
}

.profile-card-empty-title {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: #c8cdd8;
  margin-bottom: 6px;
}

.profile-card-empty-desc {
  display: block;
  font-size: 13px;
  color: var(--qm-text-tertiary);
  line-height: 1.5;
  margin-bottom: 14px;
}

.profile-card-empty-btn {
  display: inline-block;
  padding: 8px 20px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 700;
  color: var(--qm-accent-light);
  background: rgba(59, 130, 246, 0.12);
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.profile-menu-group {
  margin: 0 12px 16px;
  background: var(--qm-surface);
  border: 1px solid var(--qm-border);
  border-radius: 16px;
  overflow: hidden;
}

.profile-menu-cell {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  border-bottom: 1px solid var(--qm-border);
}

.profile-menu-cell-last {
  border-bottom: none;
}

.profile-menu-cell-press {
  background: rgba(255, 255, 255, 0.03);
}

.profile-menu-ico {
  font-size: 20px;
  width: 28px;
  text-align: center;
  flex-shrink: 0;
}

.profile-menu-text {
  flex: 1;
  min-width: 0;
}

.profile-menu-label {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: var(--qm-text);
}

.profile-menu-sub {
  display: block;
  font-size: 12px;
  color: var(--qm-text-secondary);
  margin-top: 3px;
  line-height: 1.4;
}

.profile-menu-arrow {
  font-size: 18px;
  color: #4a4d65;
  flex-shrink: 0;
}

.page-wrap .seg {
  margin: 10px 16px 0;
}

.page-wrap .sb2.on {
  color: var(--qm-accent-light, #60a5fa);
}

/* Profile avatar */
.page-wrap .pav {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  border: 2px solid var(--qm-border);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  background: var(--qm-surface);
}

.page-wrap .pav-badge {
  border-color: var(--qm-border);
  background: var(--qm-surface);
}

.profile-user-name {
  font-size: 20px;
  color: var(--qm-text);
  font-weight: 700;
}

.profile-user-sub {
  font-size: 13px;
  color: var(--qm-text-secondary);
  margin-top: 4px;
}

/* Credit ring track */
.page-wrap .ring-inner {
  background: var(--qm-bg);
}

/* Linear credit bar (utility) */
.credit-bar-track {
  background: var(--qm-border);
  border-radius: 6px;
  height: 6px;
  overflow: hidden;
}

.credit-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--qm-accent-light), #FBB924);
  border-radius: 6px;
}

/* Menu list */
.page-wrap .mnu {
  background: var(--qm-surface);
  border-bottom: 1px solid var(--qm-border);
  padding: 14px 16px;
}

.page-wrap .ml {
  font-size: 14px;
  color: var(--qm-text);
  font-weight: 600;
}

.page-wrap .msu {
  font-size: 12px;
  color: var(--qm-text-secondary);
  margin-top: 4px;
}

.page-wrap .arr {
  color: #4A4D65;
  font-size: 16px;
}

.page-wrap .mi {
  background: rgba(59, 130, 246, 0.1);
  border: 1px solid var(--qm-border);
}

.page-wrap .expand-block {
  background: var(--qm-bg);
  border-top: 1px solid var(--qm-border);
}

.page-wrap .cw {
  background: var(--qm-surface);
  border: 1px solid var(--qm-border);
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}

.fsl-placeholder {
  color: #4A4D65;
}

.logout-btn {
  color: #F87171 !important;
  border-color: #4a1a1a !important;
  background: #2a0f0f !important;
}

/* Membership */
.membership-box {
  padding: 14px 16px;
  background: linear-gradient(135deg, #1e2a1a, #162218);
  border: 1px solid rgba(52, 211, 153, 0.2);
  border-radius: 16px;
}

.membership-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.membership-label {
  font-size: 11px;
  color: var(--qm-text-secondary);
  font-weight: 600;
}

.membership-role {
  font-size: 15px;
  color: var(--qm-text);
  font-weight: 700;
  margin-top: 4px;
}

.membership-btn {
  padding: 8px 14px;
  font-size: 12px;
  flex-shrink: 0;
}

.membership-orders {
  margin-top: 10px;
  border-top: 1px solid var(--qm-border);
  padding-top: 8px;
}

.membership-order-item {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--qm-text-secondary);
  padding: 4px 0;
}

.membership-order-amt {
  color: var(--qm-accent-light);
  font-weight: 700;
}

.tier-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 12px;
}

.tier-item {
  padding: 14px 16px;
  border: 1px solid var(--qm-border);
  border-radius: 14px;
  background: var(--qm-surface);
}

.tier-on {
  border-color: rgba(59, 130, 246, 0.4);
  background: rgba(59, 130, 246, 0.08);
}

.tier-name {
  font-size: 14px;
  color: var(--qm-text);
  font-weight: 700;
}

.tier-price {
  font-size: 12px;
  color: var(--qm-accent-light);
  margin-top: 4px;
  font-weight: 700;
}

.pay-info {
  margin-bottom: 14px;
}

.pay-row {
  font-size: 12px;
  color: var(--qm-text-secondary);
  padding: 5px 0;
  font-weight: 500;
}

.pay-amt {
  font-size: 16px;
  color: var(--qm-accent-light);
  font-weight: 700;
}

/* Wallet */
.page-wrap .wallet-card {
  background: linear-gradient(135deg, var(--qm-surface) 0%, var(--qm-bg-soft) 100%);
  border: 1px solid var(--qm-border);
  border-radius: 16px;
  margin: 10px 12px;
  padding: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
}

.page-wrap .wallet-bal {
  font-size: 28px;
  color: var(--qm-text);
  font-weight: 700;
  margin: 6px 0 3px;
}

.page-wrap .ac .at {
  font-size: 15px;
  color: var(--qm-text);
  font-weight: 600;
}

.page-wrap .am {
  font-size: 12px;
  color: var(--qm-text-secondary);
}

/* 名片预览弹窗 */
.profile-card-preview-modal .mbody {
  max-height: 70vh;
  overflow-y: auto;
}

.pcp-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 8px 4px 16px;
  border-bottom: 1px solid var(--qm-border);
  margin-bottom: 14px;
}

.pcp-av-wrap {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 12px;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
}

.pcp-av,
.pcp-av-img {
  width: 72px;
  height: 72px;
  border-radius: 50%;
}

.pcp-av {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: 800;
}

.pcp-av-img {
  display: block;
}

.pcp-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--qm-text, #f1f3f9);
  line-height: 1.35;
}

.pcp-sub {
  margin-top: 6px;
  font-size: 13px;
  color: var(--qm-text-secondary, #9499b0);
  line-height: 1.5;
}

.pcp-block {
  margin-bottom: 12px;
  padding: 12px;
  border-radius: 12px;
  background: var(--qm-surface-2, rgba(255, 255, 255, 0.04));
  border: 1px solid var(--qm-border);
}

.pcp-k {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: var(--qm-accent-light, #60a5fa);
  margin-bottom: 6px;
}

.pcp-v {
  display: block;
  font-size: 14px;
  color: var(--qm-text, #f1f3f9);
  line-height: 1.6;
  word-break: break-all;
}

.pcp-actions {
  display: flex;
  gap: 8px;
  margin-top: 16px;
}

.pcp-btn {
  flex: 1;
  min-height: 44px;
  padding: 12px 0;
  font-size: 13px;
  border-radius: 12px;
  box-sizing: border-box;
}

.pcp-share-btn {
  margin: 0;
  padding: 12px 0;
  font-size: 13px;
  font-weight: 700;
  line-height: 1.4;
  border: none;
}

.pcp-share-btn::after {
  border: none;
}

.pcp-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750px;
  height: 1200px;
  opacity: 0;
  pointer-events: none;
}

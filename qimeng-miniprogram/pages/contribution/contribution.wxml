<view class="page-wrap" style="padding-top:{{headerHeight}}px;padding-bottom:{{pageBottom}}px">
  <view class="nav">
    <view class="nav-back" bindtap="goBack">‹ 返回</view>
    <text class="nav-t">贡献积分中心</text>
  </view>

  <view class="sk-list" wx:if="{{loading}}">
    <view class="sk-row" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <view class="state-box state-err" wx:elif="{{loadError}}">
    <text>{{loadError}}</text>
    <view class="btn bp btn-retry" bindtap="_load">点击重试</view>
  </view>

  <block wx:else>
    <view class="contrib-balance-card">
      <view class="contrib-balance-label">贡献积分余额</view>
      <view class="contrib-balance-val">{{balance}}</view>
      <view class="contrib-balance-hint">生态贡献积分（单位：分，不折算元）</view>
    </view>

    <view class="sec">积分兑换</view>
    <view class="contrib-actions">
      <view class="contrib-action-btn" bindtap="onConsume" data-scene="traffic_boost" disabled="{{consuming}}">
        <view class="contrib-action-title">流量扶持</view>
        <view class="contrib-action-cost">500 分</view>
        <view class="contrib-action-sub">任务推荐位 24h · 任务#{{boostTargetId}}</view>
        <picker
          mode="selector"
          range="{{myPostedTasks}}"
          range-key="title"
          value="{{boostTaskIdx}}"
          bindchange="onBoostTaskChange"
          catchtap="stopProp"
        >
          <view class="contrib-boost-picker">选择任务：{{myPostedTasks[boostTaskIdx].title || '暂无可用任务'}}</view>
        </picker>
      </view>
      <view class="contrib-action-btn" bindtap="onConsume" data-scene="credit_accel" disabled="{{consuming}}">
        <view class="contrib-action-title">信用加速</view>
        <view class="contrib-action-cost">200 分</view>
        <view class="contrib-action-sub">执行信用 +10</view>
      </view>
      <view class="contrib-action-btn" bindtap="onConsume" data-scene="perk" disabled="{{consuming}}">
        <view class="contrib-action-title">权益兑换</view>
        <view class="contrib-action-cost">1000 分</view>
        <view class="contrib-action-sub">平台权益包</view>
      </view>
    </view>

    <view class="sec">积分流水 ({{logs.length}})</view>
    <view class="cw" wx:if="{{logs.length > 0}}">
      <view class="contrib-log-row" wx:for="{{logs}}" wx:key="id">
        <view class="contrib-log-main">
          <view class="contrib-log-source">{{item.source}}</view>
          <view class="contrib-log-note" wx:if="{{item.note}}">{{item.note}}</view>
          <view class="contrib-log-time">{{item.time}}</view>
        </view>
        <view class="contrib-log-amt" style="color:{{item.amountColor}}">{{item.amountText}}</view>
      </view>
    </view>
    <view class="cw empty-hint" wx:else>
      <text>暂无贡献积分流水</text>
    </view>
  </block>
</view>

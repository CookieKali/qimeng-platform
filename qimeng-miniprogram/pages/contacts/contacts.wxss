.page-wrap { background: transparent; }

/* 导航：申请徽标 */
.contacts-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.inbox-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 2px 4px;
}

.inbox-icon-wrap {
  position: relative;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inbox-envelope-sym {
  font-size: 17px;
  line-height: 1;
}

.inbox-badge {
  position: absolute;
  top: -4px;
  right: -8px;
  min-width: 16px;
  height: 16px;
  padding: 0 4px;
  border-radius: 8px;
  background: #ff5050;
  border: 1.5px solid #0f1117;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.inbox-badge-num {
  font-size: 9px;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.inbox-label {
  font-size: 10px;
  color: var(--qm-text-secondary);
  font-weight: 600;
}

.pending-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 2px 4px;
  position: relative;
}

.pending-icon-wrap {
  position: relative;
  width: 28px;
  height: 28px;
}

.pending-entry-sym {
  font-size: 20px;
  line-height: 1;
  display: block;
  text-align: center;
  padding-top: 2px;
}

.pending-badge {
  position: absolute;
  top: -4px;
  right: -6px;
  min-width: 16px;
  height: 16px;
  padding: 0 4px;
  border-radius: 8px;
  background: #ff5050;
  border: 1.5px solid #0f1117;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.pending-badge-num {
  font-size: 9px;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.pending-label {
  font-size: 10px;
  color: #6a8aaa;
  font-weight: 700;
}

/* Tab 切换 */
.contacts-tabs {
  margin: 8px 12px 6px;
}

/* 顶部搜索区 */
.contacts-top {
  background: transparent;
  position: sticky;
  top: 0;
  z-index: 10;
}

.contacts-search .si-wrap,
.contacts-search .si-wrap-tap {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 999px;
  height: 40px;
  min-height: 40px;
  padding: 0 16px;
}

.si-wrap-tap {
  cursor: pointer;
}

.contacts-search .si-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
}

.contacts-search .si {
  flex: 1;
  height: 36px;
  line-height: 36px;
  font-size: 14px;
  color: #e8ecf4;
  background: transparent;
}

.search-inline-cancel {
  flex-shrink: 0;
  font-size: 13px;
  color: var(--qm-accent-light);
  font-weight: 700;
  padding: 0 2px;
}

.contacts-search-panel {
  margin: 0 12px 12px;
  padding: 12px;
  background: rgba(14, 24, 48, 0.55);
  border: 1px solid rgba(28, 46, 72, 0.9);
  border-radius: 12px;
  max-height: calc(100vh - 280px);
  overflow-y: auto;
  box-sizing: border-box;
}

.csp-hint,
.csp-loading,
.csp-empty {
  text-align: center;
  padding: 24px 12px;
  font-size: 13px;
  color: #4a6888;
  font-weight: 600;
}

.csp-history-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.csp-history-title {
  font-size: 12px;
  color: #5a7a9a;
  font-weight: 800;
}

.csp-history-clear {
  font-size: 11px;
  color: var(--qm-accent-light);
  font-weight: 600;
}

.csp-history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.csp-history-tag {
  padding: 6px 12px;
  border-radius: 16px;
  font-size: 12px;
  color: #8aa8c8;
  background: rgba(14, 24, 48, 0.65);
  border: 1px solid rgba(28, 46, 72, 0.9);
  font-weight: 600;
}

.csp-sec {
  margin-bottom: 14px;
}

.csp-sec-title {
  font-size: 11px;
  color: #3a5878;
  font-weight: 800;
  margin-bottom: 8px;
  padding-left: 2px;
}

.csp-list {
  background: rgba(8, 13, 24, 0.6);
  border: 1px solid rgba(28, 46, 72, 0.85);
  border-radius: 10px;
  overflow: hidden;
}

.csp-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 14px;
  border-bottom: 1px solid rgba(18, 30, 48, 0.9);
}

.csp-row:last-child {
  border-bottom: none;
}

.csp-row-press {
  background: rgba(59, 130, 246, 0.08);
}

.csp-av {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 800;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}

.csp-main {
  flex: 1;
  min-width: 0;
}

.csp-title {
  font-size: 14px;
  font-weight: 800;
  color: #e0eefc;
  line-height: 1.35;
}

.csp-sub {
  font-size: 11px;
  color: #7090b0;
  margin-top: 3px;
  font-weight: 600;
}

.csp-credits {
  color: var(--qm-accent-light);
  font-weight: 700;
}

.contacts-filters {
  padding: 8px 12px;
  background: var(--qm-surface);
  border-bottom: 1px solid var(--qm-border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.contacts-filters .fbtn.act {
  background: rgba(59, 130, 246, 0.15);
  color: var(--qm-accent-light);
  border: 1px solid rgba(59, 130, 246, 0.4);
  border-radius: 20px;
}

/* 快捷入口（暂空） */
.contacts-shortcuts {
  margin: 0 12px 6px;
  background: rgba(14, 24, 48, 0.55);
  border: 1px solid rgba(28, 46, 72, 0.9);
  border-radius: 12px;
  overflow: hidden;
}

.shortcut-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border-bottom: 1px solid rgba(18, 30, 48, 0.85);
}

.shortcut-item:last-child {
  border-bottom: none;
}

.shortcut-empty {
  opacity: 0.72;
}

.shortcut-av {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 800;
  flex-shrink: 0;
}

.shortcut-av-friends {
  background: rgba(59, 130, 246, 0.12);
  color: var(--qm-accent-light);
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.shortcut-av-circle {
  background: #1a1540;
  color: #b0a0ff;
  border: 1px solid #2a1e60;
}

.shortcut-body {
  flex: 1;
  min-width: 0;
}

.shortcut-title {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: #c8d8f0;
}

.shortcut-hint {
  display: block;
  font-size: 11px;
  color: #3a5878;
  margin-top: 2px;
  font-weight: 600;
}

/* 成员列表 */
.contacts-sec {
  font-size: 11px;
  color: #4A4D65;
  font-weight: 600;
  letter-spacing: 0.06em;
  padding: 8px 16px 4px;
}

.friend-group-bar {
  display: flex;
  gap: 8px;
  padding: 0 16px 10px;
  flex-wrap: wrap;
}

.fgb-btn {
  padding: 5px 12px;
  font-size: 11px;
  font-weight: 700;
  color: #6a8aaa;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 999px;
}

.fgb-btn.on {
  color: #5cb8ff;
  background: rgba(92, 184, 255, 0.12);
  border-color: rgba(92, 184, 255, 0.35);
}

.friend-group-block {
  margin-bottom: 4px;
}

.friend-group-hd {
  font-size: 11px;
  color: #5cb8ff;
  font-weight: 700;
  letter-spacing: 0.04em;
  padding: 6px 16px 8px;
}

.contact-tag.tag-group,
.contact-tag.tag-region {
  color: #8aa8c8;
  background: rgba(138, 168, 200, 0.12);
  border-color: rgba(138, 168, 200, 0.22);
}

.contacts-list {
  margin: 0 12px 10px;
  background: transparent;
  border: none;
  border-radius: 0;
  overflow: visible;
}

.contact-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  margin: 0 16px 10px;
  background: var(--qm-surface, #18191f);
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.18);
  transition: background 0.15s ease, transform 0.15s ease;
}

.contact-row-press {
  background: rgba(59, 130, 246, 0.08);
  transform: scale(0.995);
}

/* 活动圈 */
.circle-hint {
  margin: 0 16px 8px;
  font-size: 11px;
  color: #4a6888;
  font-weight: 600;
  line-height: 1.4;
}

.circle-row {
  align-items: flex-start;
}

.circle-row .contact-main {
  flex: 1;
  min-width: 0;
}

.circle-meta {
  font-size: 11px;
  color: #5a7a9a;
  margin-top: 4px;
  line-height: 1.35;
}

.circle-protected {
  font-size: 10px;
  color: #c9a227;
  margin-top: 4px;
  font-weight: 600;
}

.circle-action {
  flex-shrink: 0;
  align-self: center;
  margin-left: 4px;
}

.circle-action .btn-sm {
  padding: 6px 10px;
  font-size: 11px;
  white-space: nowrap;
}

.contact-av-wrap {
  position: relative;
  flex-shrink: 0;
  width: 44px;
  height: 44px;
}

.contact-av {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  flex-shrink: 0;
  border: 1.5px solid transparent;
  overflow: hidden;
}

.lv-corner {
  position: absolute;
  right: -3px;
  bottom: -2px;
  min-width: 22px;
  padding: 1px 4px;
  border-radius: 6px;
  font-size: 8px;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
  border: 1.5px solid rgba(10, 16, 32, 0.9);
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
}

.badge-sss {
  color: #FBB924;
  background: rgba(91, 141, 239, 0.15);
  border-color: rgba(91, 141, 239, 0.3);
}

.badge-ss {
  color: #C0C8D8;
  background: rgba(156, 163, 175, 0.15);
  border-color: rgba(156, 163, 175, 0.3);
}

.badge-s {
  color: #D4915A;
  background: rgba(180, 120, 60, 0.15);
  border-color: rgba(180, 120, 60, 0.3);
}

.contact-av-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.contact-main {
  flex: 1;
  min-width: 0;
}

.contact-name {
  font-size: 15px;
  font-weight: 600;
  color: #F1F3F9;
  line-height: 1.25;
}

.contact-sub {
  font-size: 12px;
  color: #9499B0;
  margin-top: 3px;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: 6px;
}

.contact-tag {
  font-size: 10px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 4px;
  line-height: 1.4;
}

.tag-credit {
  color: #7BA5EF;
  background: rgba(59, 130, 246, 0.1);
  border: 1px solid rgba(59, 130, 246, 0.25);
}

.tag-paid {
  color: #FBB924;
  background: rgba(91, 141, 239, 0.1);
  border: 1px solid rgba(91, 141, 239, 0.25);
}

.tag-friend {
  color: #34D399;
  background: rgba(52, 211, 153, 0.1);
  border: 1px solid rgba(52, 211, 153, 0.25);
}

.tag-pending,
.tag-incoming {
  color: #7090b0;
  background: rgba(112, 144, 176, 0.1);
  border: 1px solid rgba(112, 144, 176, 0.22);
}

/* 好友申请弹窗 */
.pending-empty {
  text-align: center;
  padding: 24px 12px;
  font-size: 13px;
  color: #5a7a9a;
  font-weight: 600;
}

.req-card {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid #121e30;
}

.req-card:last-child {
  border-bottom: none;
}

.req-body {
  flex: 1;
  min-width: 0;
}

.req-msg {
  font-size: 11px;
  color: #5a8ab0;
  margin-top: 4px;
  line-height: 1.5;
}

.req-actions {
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex-shrink: 0;
}

.si-ph { color: #4a6888; }

.state-box {
  margin: 12px;
  padding: 28px 16px;
  text-align: center;
  font-size: 14px;
  color: #6a8aaa;
  font-weight: 600;
  line-height: 1.6;
  background: rgba(14, 24, 48, 0.6);
  border-radius: 14px;
  border: 1px solid #1c2e48;
}

.state-err {
  color: #ff9898;
  border-color: rgba(255, 120, 120, 0.25);
  background: rgba(52, 12, 12, 0.35);
}

.btn-retry {
  margin: 14px auto 0;
  max-width: 200px;
  padding: 10px 0;
  font-size: 14px;
}

.match-summary {
  font-size: 12px;
  color: #a8c8e8;
  font-weight: 700;
  margin-bottom: 12px;
  line-height: 1.6;
}

.match-sec-t {
  font-size: 10px;
  color: #3a5878;
  font-weight: 800;
  margin: 8px 0 6px;
}

.match-row {
  background: #070d1a;
  border: 1px solid #1c2e48;
  border-radius: 9px;
  padding: 9px 11px;
  margin-bottom: 6px;
}

.match-row-tap:active {
  opacity: 0.85;
  border-color: rgba(59, 130, 246, 0.45);
}

.match-name {
  display: block;
  font-size: 12px;
  font-weight: 700;
  color: #e0eefc;
}

.match-meta {
  display: block;
  font-size: 10px;
  color: #7090b0;
  margin-top: 3px;
  font-weight: 500;
}

.contacts-sub-modal.ov,
.contacts-layer-ov.ov,
.contacts-guide-ov.ov {
  z-index: 300;
}

.contacts-guide-ov .guide-modal {
  max-width: 340px;
  background: #080d18;
  border: 1px solid rgba(91, 141, 239, 0.28);
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.45);
}

.guide-modal-body {
  padding: 24px 20px 20px;
}

.guide-title {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: #e8ecf4;
  text-align: center;
  line-height: 1.35;
}

.guide-desc {
  display: block;
  margin-top: 10px;
  font-size: 14px;
  color: #8aa8c8;
  text-align: center;
  line-height: 1.6;
}

.guide-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 6px 4px;
  margin: 20px 0 22px;
  padding: 14px 10px;
  background: rgba(91, 141, 239, 0.08);
  border: 1px solid rgba(91, 141, 239, 0.2);
  border-radius: 14px;
}

.guide-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  min-width: 72px;
}

.guide-step-num {
  width: 22px;
  height: 22px;
  line-height: 22px;
  text-align: center;
  border-radius: 50%;
  background: rgba(91, 141, 239, 0.2);
  color: #5B8DEF;
  font-size: 12px;
  font-weight: 700;
}

.guide-step-text {
  font-size: 11px;
  color: #a8c8e8;
  font-weight: 600;
  text-align: center;
  line-height: 1.35;
}

.guide-step-arrow {
  font-size: 14px;
  color: #5B8DEF;
  font-weight: 700;
  flex-shrink: 0;
}

.guide-actions {
  display: flex;
  gap: 10px;
}

.guide-actions .btn {
  flex: 1;
  padding: 12px 0;
  font-size: 14px;
}

.guide-btn-later {
  background: rgba(255, 255, 255, 0.06);
  color: #8aa8c8;
  border: 1px solid rgba(138, 168, 200, 0.25);
}

.guide-btn-primary {
  background: #5B8DEF;
  color: #fff;
  box-shadow: 0 4px 16px rgba(91, 141, 239, 0.35);
}

.share-card-ov .mb {
  max-width: 400px;
}

/* 数字名片 · 居中弹窗 */
.card-drawer-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0);
  pointer-events: none;
  transition: background 0.28s ease;
}

.card-drawer-mask.dcard-modal-mask {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card-drawer-mask.show {
  background: rgba(0, 0, 0, 0.62);
  pointer-events: auto;
}

.card-drawer {
  position: relative;
  z-index: 201;
  display: flex;
  flex-direction: column;
  background: #080d18;
  overflow: hidden;
  box-sizing: border-box;
}

.card-drawer.dcard-modal {
  width: 92%;
  max-width: 640rpx;
  max-height: 92vh;
  border-radius: 36rpx;
  border: 1px solid rgba(59, 130, 246, 0.2);
  box-shadow: 0 20rpx 56rpx rgba(0, 0, 0, 0.5);
  transform: scale(0.96);
  opacity: 0;
  transition: transform 0.24s ease, opacity 0.24s ease;
}

.card-drawer.open {
  transform: scale(1);
  opacity: 1;
}

.dcard-topbar {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 20rpx 24rpx 12rpx;
  flex-shrink: 0;
}

.dcard-brand {
  font-size: 24rpx;
  font-weight: 700;
  color: #c9a227;
  letter-spacing: 0.08em;
}

.dcard-close {
  position: absolute;
  right: 12px;
  top: 10px;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  color: #9aa5b8;
  font-weight: 400;
  line-height: 1;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.dcard-modal .dcard-scroll {
  width: 100%;
  height: 68vh;
  max-height: 780rpx;
  min-height: 420rpx;
  padding: 0 32rpx 20rpx;
  box-sizing: border-box;
}

.dcard-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 4rpx 0 20rpx;
}

.dcard-av-wrap {
  width: 168rpx;
  height: 168rpx;
  margin-bottom: 24rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(59, 130, 246, 0.12), 0 8rpx 28rpx rgba(0, 0, 0, 0.4);
}

.dcard-av,
.dcard-av-img {
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  box-sizing: border-box;
  border: 2rpx solid rgba(59, 130, 246, 0.55);
}

.dcard-av {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 800;
}

.dcard-av-img {
  display: block;
}

.dcard-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #f5f7fa;
  line-height: 1.3;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dcard-headline {
  font-size: 26rpx;
  color: #9aa5b8;
  margin-top: 10rpx;
  font-weight: 500;
  line-height: 1.45;
  max-width: 100%;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.dcard-profile-co {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 16rpx;
  max-width: 100%;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.dcard-profile-co-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  margin-right: 0;
}

.dcard-profile-co-text {
  font-size: 26rpx;
  color: #c8d0dc;
  font-weight: 600;
  line-height: 1.4;
  text-align: left;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dcard-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.dcard-tag {
  font-size: 12px;
  font-weight: 600;
  padding: 5px 14px;
  border-radius: 20px;
}

.dcard-tag-gold {
  color: #ffffff;
  background: #3a6fd8;
  border: none;
  font-size: 12px;
  font-weight: 600;
  padding: 5px 14px;
}

.dcard-tag-credit {
  color: #e8b84b;
  background: rgba(232, 184, 75, 0.12);
  border: 1px solid rgba(232, 184, 75, 0.4);
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
  padding: 5px 14px;
}

.dcard-tag-friend {
  color: #34D399;
  background: rgba(52, 211, 153, 0.1);
  border: none;
  font-size: 12px;
  padding: 5px 14px;
}

.dcard-block {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.dcard-block:last-of-type {
  border-bottom: none;
}

.dcard-label {
  font-size: 12px;
  color: var(--qm-accent-light);
  font-weight: 700;
  margin-bottom: 6px;
  letter-spacing: 0.03em;
}

.dcard-text {
  font-size: 26rpx;
  color: #d4d8e0;
  line-height: 1.65;
  font-weight: 400;
  text-align: left;
  word-break: break-all;
}

.dcard-portfolio-hd {
  font-size: 24rpx;
  color: var(--qm-accent-light);
  font-weight: 700;
  margin: 8rpx 0 16rpx;
}

.dcard-contact.dcard-block {
  border-bottom: none;
  padding-bottom: 8rpx;
}

.dcard-portfolio-item {
  background: #111c33;
  border: 1rpx solid rgba(59, 130, 246, 0.12);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.dcard-portfolio-cat {
  font-size: 30rpx;
  font-weight: 800;
  color: #e8b84b;
  margin-bottom: 8rpx;
}

.dcard-portfolio-role {
  font-size: 12px;
  color: #6b7a99;
  margin-bottom: 8px;
  font-weight: 500;
}

.dcard-portfolio-line {
  font-size: 13px;
  color: #b8c4d4;
  line-height: 1.7;
  margin-top: 3px;
}

.dcard-k {
  color: #6b7a99;
  margin-right: 4px;
  font-weight: 600;
}

.dcard-privacy-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(217, 119, 6, 0.1);
  border: 1rpx solid rgba(217, 119, 6, 0.28);
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  margin: 4rpx 0 8rpx;
}

.dcard-privacy-sym {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #d97706;
  line-height: 1;
}

.dcard-privacy-text {
  flex: 1;
  color: #d97706;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 500;
}

.dcard-qr-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0 12rpx;
  margin-top: 8rpx;
}

.dcard-qr-img {
  width: 160px;
  height: 160px;
  border-radius: 6px;
  background: #fff;
}

.dcard-qr {
  width: 160px;
  height: 160px;
  border-radius: 6px;
  background-color: #fff;
  background-image:
    linear-gradient(45deg, #d0d0d0 25%, transparent 25%),
    linear-gradient(-45deg, #d0d0d0 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #d0d0d0 75%),
    linear-gradient(-45deg, transparent 75%, #d0d0d0 75%);
  background-size: 20px 20px;
  background-position: 0 0, 0 10px, 10px -10px, -10px 0;
}

.dcard-qr-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6a8aaa;
  font-weight: 600;
}

.dcard-contact .drawer-contact-row {
  padding: 20rpx 0;
}

.dcard-contact .contact-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
}

.dcard-contact .contact-sym {
  font-size: 32rpx;
}

.dcard-contact .drawer-contact-k {
  font-size: 22rpx;
}

.dcard-contact .drawer-contact-v {
  font-size: 28rpx;
  margin-top: 4rpx;
}

.card-drawer-body {
  flex: 1;
  min-height: 0;
}

.card-drawer-ft,
.dcard-modal .dcard-ft {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 20rpx 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  background: #080d18;
  flex-shrink: 0;
  flex-wrap: wrap;
}

.dcard-modal .card-ft-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 18rpx 0;
  min-width: 0;
}

.card-ft-disabled {
  opacity: 0.55;
  color: #6a8aaa !important;
  border-color: #2a4060 !important;
  background: #0e1830 !important;
}

.card-drawer-ft {
  flex-wrap: wrap;
}

/* 转发名片弹窗 */
.share-modal .mbody {
  max-height: 72vh;
  overflow-y: auto;
}

.share-action-disabled {
  opacity: 0.45;
  pointer-events: none;
}

.share-preview-hint {
  font-size: 10px;
  color: #3a5878;
  margin-bottom: 8px;
  font-weight: 700;
}

.share-preview-card {
  margin-bottom: 14px;
}

.share-preview-head {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 11px;
}

.share-preview-av-wrap,
.share-friend-av-wrap {
  width: 46px;
  height: 46px;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
}

.share-friend-av-wrap {
  width: 40px;
  height: 40px;
}

.share-preview-av-img,
.share-friend-av-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
}

.share-preview-av {
  width: 46px;
  height: 46px;
  font-size: 15px;
}

.share-preview-info {
  flex: 1;
  min-width: 0;
}

.share-preview-meta {
  border-top: 1px solid #e8ecf2;
  padding-top: 10px;
}

.share-preview-meta .pc-k {
  font-weight: 700;
  color: #0a1428;
  margin-right: 8px;
}

.share-sec-t {
  font-size: 11px;
  color: #3a5878;
  font-weight: 800;
  margin-bottom: 8px;
}

.share-search-wrap {
  display: flex;
  align-items: center;
  min-height: 40px;
  padding: 0 12px;
  margin-bottom: 10px;
  background: #070d1a;
  border: 1.5px solid #1c2e48;
  border-radius: 10px;
  box-sizing: border-box;
}


.share-search-input {
  flex: 1;
  font-size: 13px;
  color: #c8e0f8;
  min-height: 38px;
}

.share-search-ph {
  color: #4a6888;
  font-weight: 500;
}

.share-friend-list {
  max-height: 220px;
  overflow-y: auto;
  margin-bottom: 12px;
}

.share-friend-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 11px;
  margin-bottom: 6px;
  background: #070d1a;
  border: 1.5px solid #1c2e48;
  border-radius: 11px;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.share-friend-row.on {
  border-color: var(--qm-accent-light);
  background: rgba(59, 130, 246, 0.1);
  box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.2);
}

.share-friend-av {
  width: 40px;
  height: 40px;
  font-size: 12px;
}

.share-friend-info {
  flex: 1;
  min-width: 0;
}

.share-friend-name {
  font-size: 13px;
  font-weight: 800;
  color: #e0eefc;
}

.share-friend-job {
  font-size: 10px;
  color: #7090b0;
  margin-top: 2px;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.share-friend-check {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--qm-accent-light);
  color: #F1F3F9;
  font-size: 12px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.share-friend-empty {
  text-align: center;
  padding: 16px 8px;
  font-size: 12px;
  color: #5a7a9a;
  font-weight: 600;
  margin-bottom: 12px;
}

.share-actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-top: 12px;
  margin-top: 4px;
  border-top: 1px solid #1c2e48;
}

.share-action-btn {
  box-sizing: border-box;
  min-height: 44px;
  padding: 12px 16px;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.35;
  border-radius: 12px;
  margin: 0;
  flex: none;
  width: 100%;
}

.share-action-primary {
  font-size: 15px;
}

.share-actions-row {
  display: flex;
  gap: 10px;
}

.share-action-secondary {
  flex: 1;
  width: auto;
  min-width: 0;
  font-size: 14px;
}

.share-wx-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--qm-surface-2, #1e2434);
  color: var(--qm-text-secondary, #9499b0);
  border: 1px solid var(--qm-border, #2a2d3a);
}

.share-wx-btn::after {
  border: none;
}

.share-action-btn[disabled] {
  opacity: 0.45;
}

/* 名片抽屉 · 互换状态 */
.card-hint-bar {
  width: 100%;
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 13px;
  margin-bottom: 12px;
  box-sizing: border-box;
  font-weight: 600;
  line-height: 1.5;
}

.hint-bar-yellow {
  background: rgba(91, 141, 239, 0.1);
  color: #FBB924;
  border: 1px solid rgba(91, 141, 239, 0.25);
}

.hint-bar-green {
  background: rgba(52, 211, 153, 0.1);
  color: #34D399;
  border: 1px solid rgba(52, 211, 153, 0.25);
}

.dcard-ft {
  flex-direction: column;
  align-items: stretch;
}

.dcard-ft-actions {
  display: flex;
  gap: 8px;
  width: 100%;
}

.dcard-ft-actions .card-ft-btn {
  flex: 1;
}

.dcard-ft-hint {
  font-size: 11px;
  color: #4A4D65;
  text-align: center;
  margin-top: 8px;
  line-height: 1.5;
  font-weight: 500;
}

.card-ft-primary {
  width: 100%;
}

.drawer-contact-row {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--qm-border);
}

.drawer-contact-row:last-child {
  border-bottom: none;
}

.contact-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #1e2130;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.contact-sym {
  font-size: 32rpx;
  color: var(--qm-accent-light);
  line-height: 1;
}

.drawer-contact-body {
  flex: 1;
  min-width: 0;
}

.drawer-contact-k {
  font-size: 22rpx;
  color: #4A4D65;
  font-weight: 600;
}

.drawer-contact-v {
  font-size: 28rpx;
  color: #F1F3F9;
  margin-top: 4rpx;
  font-weight: 600;
  word-break: break-all;
}
